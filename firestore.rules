rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Customer rules
    match /customers/{customerId} {
      allow read: if isSignedIn();
      // Only admins or system should write customers normally, but for a PoC/transplant we allow staff
      allow create: if isSignedIn() && isEmailVerified();
      allow update: if isSignedIn() && isEmailVerified();

      match /family/{memberId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isEmailVerified();
      }
    }

    // Report rules
    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() 
        && incoming().reporterId == request.auth.uid
        && incoming().timestamp == request.time;
      allow update: if isSignedIn() && isEmailVerified() 
        && existing().reporterId == request.auth.uid;
      allow delete: if isSignedIn() && isEmailVerified() 
        && existing().reporterId == request.auth.uid;
    }

    // Receipt rules
    match /receipts/{receiptId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() 
        && incoming().staffId == request.auth.uid
        && incoming().timestamp == request.time;
      allow update: if isSignedIn() && isEmailVerified() 
        && existing().staffId == request.auth.uid;
      allow delete: if isSignedIn() && isEmailVerified() 
        && existing().staffId == request.auth.uid;
    }
  }
}
